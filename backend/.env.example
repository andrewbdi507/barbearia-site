# ============================================================
# Barbershop SaaS — Environment Variables (Complete)
# ============================================================
# Copy: cp .env.example .env
# Fill in values marked with <...>
# WARNING: Never commit .env to version control.

# ============================================================
# 1. ENVIRONMENT
# ============================================================
APP_ENV=development
APP_DEBUG=true
APP_NAME=barbershop-saas
APP_VERSION=1.1.0

# ============================================================
# 2. SERVER
# ============================================================
HOST=0.0.0.0
PORT=8000
WORKERS=1

# ============================================================
# 3. DATABASE (PostgreSQL)
# ============================================================
DATABASE_URL=postgresql+asyncpg://barbershop:barbershop@localhost:5432/barbershop_dev
DATABASE_URL_SYNC=postgresql://barbershop:barbershop@localhost:5432/barbershop_dev
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
DATABASE_POOL_TIMEOUT=30
DATABASE_ECHO=false

# ============================================================
# 4. REDIS (Cache + Queue)
# ============================================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# ============================================================
# 5. SECURITY
# ============================================================
SECRET_KEY=<generate-with-python-secrets.token_hex(32)>
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# 6. CORS
# ============================================================
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ============================================================
# 7. RATE LIMITING
# ============================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=5/minute

# ============================================================
# 8. LOGGING
# ============================================================
LOG_LEVEL=DEBUG
LOG_FORMAT=json
LOG_COLORIZE=true

# ============================================================
# 9. MONITORING
# ============================================================
SENTRY_DSN=
OTEL_EXPORTER_ENABLED=false

# ============================================================
# 10. STORAGE (local | s3 | r2 | gcs | azure)
# ============================================================
STORAGE_PROVIDER=local
# S3
STORAGE_S3_BUCKET=<your-bucket>
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=<your-key>
STORAGE_S3_SECRET_KEY=<your-secret>
# R2
STORAGE_R2_ACCOUNT_ID=<account-id>
STORAGE_R2_ACCESS_KEY=<your-key>
STORAGE_R2_SECRET_KEY=<your-secret>
STORAGE_R2_BUCKET=<your-bucket>
# GCS
STORAGE_GCS_BUCKET=<your-bucket>
STORAGE_GCS_CREDENTIALS_FILE=/path/to/sa.json
# Azure
STORAGE_AZURE_CONNECTION_STRING=<connection-string>
STORAGE_AZURE_CONTAINER=<container>

# ============================================================
# 11. PAYMENT GATEWAYS
# ============================================================

# --- Mercado Pago ---
MERCADOPAGO_ACCESS_TOKEN=<your-token>
MERCADOPAGO_PUBLIC_KEY=<your-public-key>
MERCADOPAGO_WEBHOOK_SECRET=<your-secret>
MERCADOPAGO_ENVIRONMENT=sandbox

# --- Stripe ---
STRIPE_SECRET_KEY=<sk_live_...>
STRIPE_PUBLISHABLE_KEY=<pk_live_...>
STRIPE_WEBHOOK_SECRET=<whsec_...>
STRIPE_ENVIRONMENT=test

# --- Asaas (Brasil) ---
ASAAS_API_KEY=<your-api-key>
ASAAS_WEBHOOK_SECRET=<your-secret>
ASAAS_ENVIRONMENT=sandbox

# ============================================================
# 12. NOTIFICATIONS
# ============================================================

# --- WhatsApp (Meta Cloud API) ---
WHATSAPP_PROVIDER=meta
WHATSAPP_PHONE_NUMBER_ID=<id>
WHATSAPP_BUSINESS_ACCOUNT_ID=<id>
WHATSAPP_ACCESS_TOKEN=<token>
WHATSAPP_API_VERSION=v21.0

# --- WhatsApp (Twilio) ---
TWILIO_ACCOUNT_SID=<sid>
TWILIO_AUTH_TOKEN=<token>
TWILIO_WHATSAPP_FROM=whatsapp:+5511999999999

# --- Email (resend | smtp | sendgrid | ses) ---
EMAIL_PROVIDER=resend
RESEND_API_KEY=<re_...>
RESEND_FROM_EMAIL=noreply@seudominio.com.br
# SMTP
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=<user>
SMTP_PASSWORD=<password>
# SendGrid
SENDGRID_API_KEY=<SG....>
# Amazon SES
AWS_SES_REGION=us-east-1

# --- SMS (twilio | zenvia) ---
SMS_PROVIDER=twilio
TWILIO_SMS_FROM=+5511999999999
ZENVIA_API_KEY=<key>

# --- Push ---
FIREBASE_CREDENTIALS_FILE=/path/to/sa.json

# ============================================================
# 13. CDN
# ============================================================
CDN_ENABLED=false
CDN_BASE_URL=https://cdn.seudominio.com.br

# ============================================================
# 14. FEATURE FLAGS
# ============================================================
FEATURE_PAYMENTS_ENABLED=true
FEATURE_WHATSAPP_ENABLED=true
FEATURE_EMAIL_ENABLED=true
FEATURE_SMS_ENABLED=false
FEATURE_PUSH_ENABLED=false

# ============================================================
# 15. AGENTS & AI
# ============================================================
# Agent URLs (container names inside Docker network)
AND_AGENT_URL=http://and-agent:8000
AND_AGENT_ENABLED=true
HERMES_AGENT_URL=http://hermes-agent:8000
HERMES_AGENT_ENABLED=true
EVOLVER_URL=http://evolver-agent:8000
EVOLVER_ENABLED=true
GENERIC_AGENT_URL=http://generic-agent:8000
GENERIC_AGENT_ENABLED=true
CLAUDE_MEM_URL=http://claude-mem-agent:8000
CLAUDE_MEM_ENABLED=true
AGENT_TIMEOUT=30
AGENT_RETRY_ATTEMPTS=3
